---
const currentYear = new Date().getFullYear();
---
<footer id="contato" class="bg-olive/60 text-graphite/80 pt-20 pb-20 md:pb-12 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-terracotta/5 rounded-full blur-[100px] -z-0"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-12 gap-16 mb-16">

      <!-- Brand -->
      <div class="lg:col-span-5">
        <h3 class="text-4xl font-serif mb-8 text-graphite/70 tracking-tighter">
          Marcio<span class="text-terracotta">Trombeta</span>
        </h3>
        <p class="text-graphite/70 font-light leading-relaxed mb-10 max-w-sm text-lg">
          A excelência no toque como ferramenta de regeneração e equilíbrio sistêmico.
        </p>
        <div class="flex space-x-6">
          <a href="https://www.instagram.com/marciotrombeta_masso/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center hover:bg-terracotta transition-all duration-500 group">
            <!-- Instagram SVG -->
            <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/p/Marcio-Trombeta-Massoterapeuta-61563027525852/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center hover:bg-terracotta transition-all duration-500 group">
            <!-- Facebook SVG -->
            <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@marcio.trombeta.m?_r=1&_t=ZS-959MIj1nc49" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center hover:bg-terracotta transition-all duration-500 group">
            <!-- TikTok SVG -->
            <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1 .05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="lg:col-span-3">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] mb-10 text-graphite/70">Navegação</h4>
        <ul class="space-y-6 text-graphite/70 font-light text-sm">
          <li><a href="#inicio" class="hover:text-graphite transition-colors">Início</a></li>
          <li><a href="#sobre" class="hover:text-graphite transition-colors">Sobre</a></li>
          <li><a href="/#tecnicas" class="hover:text-graphite transition-colors">Técnicas</a></li>
          <li><a href="/#locais" class="hover:text-graphite transition-colors">Locais de Atendimento</a></li>
          <li><a href="/privacidade" class="hover:text-graphite transition-colors">Privacidade e Termos</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-4">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] mb-10 text-graphite/70">Localização</h4>
        <ul class="space-y-8 text-graphite/70 font-light text-sm">
          <li class="flex items-start space-x-4">
            <!-- MapPin -->
            <svg class="text-graphite/70 shrink-0 mt-1 w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <div class="leading-relaxed">
              <span class="block text-graphite/70 font-medium mb-1">Clínica Sublime (Principal)</span>
              Rua Rozo Lagoa 68, Imirim <br/><span class="text-graphite/70">São Paulo – SP</span>
            </div>
          </li>
          <li class="flex items-start space-x-4 border-t border-white/10 pt-4 mt-4">
            <!-- MapPin -->
            <svg class="text-graphite/70 shrink-0 mt-1 w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <div class="leading-relaxed">
              <span class="block text-graphite/70 font-medium mb-1">Paulista</span>
              Atendimento em espaço reservado próximo ao metrô Brigadeiro (Alameda Santos).<br/>
              <span class="text-graphite/70 text-xs mt-1 block">Para mais informações, entre em contato para agendamento.</span>
            </div>
          </li>
          <li class="flex items-center space-x-4">
            <!-- Phone -->
            <svg class="text-graphite/70 shrink-0 w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <span class="text-graphite/70">(11) 99837-4338</span>
          </li>
          <li class="flex items-center space-x-4">
            <!-- Mail -->
            <svg class="text-graphite/70 shrink-0 w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <span class="text-graphite/70">Marciotrombeta@yahoo.com.br</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/5 grid grid-cols-1 md:grid-cols-3 gap-4 items-center text-[10px] font-bold uppercase tracking-[0.2em] text-graphite/70 text-center md:text-left">
      <p class="md:col-span-1">© {currentYear} Marcio Trombeta.</p>
      <div class="md:col-span-1 flex items-center justify-center space-x-2">
        <span class="text-graphite/70">Desenvolvido por</span>
        <a href="https://www.instagram.com/nexusdigital.tech/" target="_blank" rel="noopener noreferrer" class="text-graphite hover:text-terracotta transition-colors flex items-center space-x-1 font-black tracking-widest">
          NEXUS DIGITAL
        </a>
      </div>
      <div class="md:col-span-1 hidden md:block"></div>
    </div>
  </div>
</footer>
