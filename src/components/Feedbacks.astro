---
const feedbacks = [

  {
    image: "/feedback2.avif",
    alt: "Feedback de cliente 2"
  },
  {
    image: "/feedback3.avif",
    alt: "Feedback de cliente 3"
  },
  {
    image: "/feedback4.avif",
    alt: "Feedback de cliente 4"
  },
  {
    image: "/feedback5.avif",
    alt: "Feedback de cliente 5"
  }
];
---

<section class="py-32 bg-primary overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20">
      <div class="max-w-2xl">
        <span class="text-[12px] font-bold text-terracotta uppercase tracking-[0.4em] mb-4 block reveal">
          Mensagens de Clientes
        </span>
        <h2 class="text-5xl md:text-7xl font-serif text-graphite reveal">
          O que nossos clientes <span class="italic font-light">falam</span>.
        </h2>
      </div>
    </div>

    <!-- Carousel Container -->
    <div class="relative">
      <div class="overflow-hidden">
        <div 
          id="carousel-track" 
          class="flex gap-6 md:gap-8 transition-transform duration-500 ease-out cursor-grab active:cursor-grabbing"
          style="width: fit-content;"
        >
          {feedbacks.map((feedback, index) => (
            <div
              class="flex-shrink-0 w-full sm:w-1/2 lg:w-1/3"
              data-slide={index}
            >
              <div class="relative aspect-[16/9] overflow-hidden rounded-[24px] border border-graphite/10 hover:border-terracotta/30 transition-all duration-700">
                <img 
                  src={feedback.image}
                  alt={feedback.alt}
                  class="w-full h-full object-cover transition-transform duration-700 select-none"
                  loading="lazy"
                  draggable="false"
                />
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Buttons (visible only on desktop) -->
      <button 
        id="carousel-prev" 
        class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 -translate-x-16 z-10 p-3 rounded-full bg-graphite/10 hover:bg-terracotta/20 transition-all duration-300 group items-center justify-center"
        aria-label="Slide anterior"
      >
        <svg class="w-6 h-6 text-graphite group-hover:text-terracotta transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <button 
        id="carousel-next" 
        class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 z-10 p-3 rounded-full bg-graphite/10 hover:bg-terracotta/20 transition-all duration-300 group items-center justify-center"
        aria-label="Próximo slide"
      >
        <svg class="w-6 h-6 text-graphite group-hover:text-terracotta transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Indicators -->
      <div class="flex justify-center items-center gap-2 mt-8">
        {feedbacks.map((_, index) => (
          <button
            class="carousel-indicator w-3 h-3 rounded-full transition-all duration-500 bg-graphite/20 hover:bg-terracotta/40"
            data-index={index}
            aria-label={`Ir para slide ${index + 1}`}
          />
        ))}
      </div>
    </div>
  </div>

  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-terracotta/5 rounded-full -mr-48 -mt-48 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-terracotta/5 rounded-full -ml-48 -mb-48 blur-3xl pointer-events-none"></div>
</section>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const indicators = document.querySelectorAll('.carousel-indicator');
  const container = track?.parentElement;
  
  let currentIndex = 0;
  const totalSlides = indicators.length;
  let isGrabbing = false;
  let startX = 0;
  let currentX = 0;
  let startTransform = 0;

  // Get number of visible items based on screen size
  function getVisibleItems() {
    if (window.innerWidth < 640) return 1; // mobile
    if (window.innerWidth < 1024) return 2; // tablet
    return 3; // desktop
  }

  // Calculate slide width
  function getSlideWidth() {
    if (!container) return 0;
    const rect = container.getBoundingClientRect();
    const items = getVisibleItems();
    return rect.width / items;
  }

  function updateCarousel() {
    if (!track) return;
    const slideWidth = getSlideWidth();
    const offset = currentIndex * -slideWidth;
    track.style.transform = `translateX(${offset}px)`;
    
    // Update indicators
    indicators.forEach((indicator, index) => {
      if (index === currentIndex) {
        indicator.classList.remove('bg-graphite/20');
        indicator.classList.add('bg-terracotta', 'w-8');
      } else {
        indicator.classList.remove('bg-terracotta', 'w-8');
        indicator.classList.add('bg-graphite/20');
      }
    });
  }

  function nextSlide() {
    const visibleItems = getVisibleItems();
    const maxIndex = Math.max(0, totalSlides - visibleItems);
    currentIndex = Math.min(currentIndex + 1, maxIndex);
    updateCarousel();
  }

  function prevSlide() {
    currentIndex = Math.max(currentIndex - 1, 0);
    updateCarousel();
  }

  // Mouse drag
  track?.addEventListener('mousedown', (e) => {
    isGrabbing = true;
    startX = e.clientX;
    startTransform = track.getBoundingClientRect().left;
    track.style.transition = 'none';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isGrabbing || !track) return;
    currentX = e.clientX - startX;
    const slideWidth = getSlideWidth();
    const currentPos = currentIndex * -slideWidth;
    track.style.transform = `translateX(${currentPos + currentX}px)`;
  });

  document.addEventListener('mouseup', () => {
    if (!isGrabbing || !track) return;
    isGrabbing = false;
    track.style.transition = 'transform 0.5s ease-out';
    
    const threshold = 50;
    if (currentX > threshold) {
      prevSlide();
    } else if (currentX < -threshold) {
      nextSlide();
    } else {
      updateCarousel();
    }
    currentX = 0;
  });

  // Touch drag
  track?.addEventListener('touchstart', (e) => {
    isGrabbing = true;
    startX = e.touches[0].clientX;
    track.style.transition = 'none';
  });

  track?.addEventListener('touchmove', (e) => {
    if (!isGrabbing || !track) return;
    currentX = e.touches[0].clientX - startX;
    const slideWidth = getSlideWidth();
    const currentPos = currentIndex * -slideWidth;
    track.style.transform = `translateX(${currentPos + currentX}px)`;
  });

  track?.addEventListener('touchend', () => {
    if (!isGrabbing || !track) return;
    isGrabbing = false;
    track.style.transition = 'transform 0.5s ease-out';
    
    const threshold = 50;
    if (currentX > threshold) {
      prevSlide();
    } else if (currentX < -threshold) {
      nextSlide();
    } else {
      updateCarousel();
    }
    currentX = 0;
  });

  prevBtn?.addEventListener('click', prevSlide);
  nextBtn?.addEventListener('click', nextSlide);

  // Indicator click
  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
    });
  });

  // Handle resize
  window.addEventListener('resize', updateCarousel);

  // Initialize
  updateCarousel();
</script>
