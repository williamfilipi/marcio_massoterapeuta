---
const differentials = [
  {
    title: "Alívio de Tensões",
    description: "Técnicas focadas em desatar nós musculares e liberar o estresse acumulado no dia a dia."
  },
  {
    title: "Equilíbrio Emocional",
    description: "Um espaço seguro para reconectar-se consigo mesmo e acalmar a mente através do toque."
  },
  {
    title: "Recuperação Física",
    description: "Acelere a recuperação muscular e melhore a circulação com manobras precisas."
  }
];

// SVG icons as inline strings
const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 013 10c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.623 0-1.31-.21-2.571-.602-3.751h-.2c-1.77 0-3.432-.57-4.798-1.536z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`
];
---
<section class="pt-12 pb-20 md:py-32 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12">
      {differentials.map((item, index) => (
        <div class="relative group reveal" style={`transition-delay: ${index * 0.2}s`}>
          <div class="p-12 rounded-[48px] bg-primary border border-graphite/5 hover:border-terracotta/20 transition-all duration-700 h-full relative z-10">
            <div class="mb-10 inline-block p-5 bg-white rounded-3xl shadow-[0_20px_40px_-10px_rgba(0,0,0,0.1)] group-hover:scale-110 transition-transform duration-700">
              <Fragment set:html={icons[index]} />
            </div>
            <h3 class="text-3xl font-serif mb-6 text-graphite group-hover:text-terracotta transition-colors duration-500">{item.title}</h3>
            <p class="text-graphite/80 font-light leading-relaxed text-sm">{item.description}</p>
          </div>
          <div class="absolute -inset-2 bg-terracotta/5 rounded-[52px] opacity-0 group-hover:opacity-100 transition-opacity duration-700 -z-0"></div>
        </div>
      ))}
    </div>
  </div>
</section>


